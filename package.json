{
  "name": "string-helpers",
  "version": "0.2.0",
  "description": "String helpers collection",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/esm/string-helpers.js",
      "require": "./dist/cjs/string-helpers.js"
    }
  },
  "scripts": {
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build:umd": "webpack --config webpack.config.mjs",
    "build": "pnpm run build:esm && pnpm run build:cjs && pnpm run build:umd",
    "lint": "eslint",
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/johnsmith9264/string-helpers-js.git"
  },
  "keywords": [
    "library",
    "javascript"
  ],
  "author": "Andriy Fetsyuk <forspam.smith@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/johnsmith9264/string-helpers/issues"
  },
  "homepage": "https://github.com/johnsmith9264/string-helpers#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "ts-loader": "^9.5.4",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}